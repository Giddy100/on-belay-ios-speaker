    "sign_in_explanation" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Belay is On enables multi pitch climbers communicate handsfree as long as there is reception. The App is free to use and doesn’t share anything with anyone. It was created by a climber for climbers."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האפליקציה מאפשרת למטפסי מולטי פיץ׳ לתקשר ללא נגיעה בטלפון כל עוד יש תקשורת סלולרית. האפליקציה ניתנת בחינם ואינה משתפת שום מידע עם שום גוף. היא נוצרה על ידי מטפס עבור מטפסים."
          }
        }
      }
    },
