    "help" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Help"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עזרה"
          }
        }
      }
    },
    "help_content_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Join an existing group or create your own."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. יש ליצור קבוצה או להצטרף לאחת קיימת"
          }
        }
      }
    },
    "help_content_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. Tap \"ACTIVATE LISTENING\" when you start climbing. You\\'ll see \"Wait for \\'Hey Moses\\'\" in the monitor."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. יש ללחוץ על \\'התחלת האזנה\\'. במוניטור יופיע שמחקים למילת הערה"
          }
        }
      }
    },
    "help_content_3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. Say \"Hey Moses\" to wake up the app. It will respond with \"Listening\" and wait for your command."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. יש לאמור \\'Hey Moses\\'"
          }
        }
      }
    },
    "help_content_4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4. Say one of your group\\'s command (e.g., \"Climbing\", \"Belay is On\", \"Off Belay\")."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4. יש לומר את אחת הפקודות באנגלית כמו Off Belay או Climbing וכו"
          }
        }
      }
    },
    "help_content_5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5. You can also use the \"QUICK SEND\" button to manually broadcast a command without speaking."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5. ניתן גם ללחוץ על QUICK SEND"
          }
        }
      }
    },
    "help_content_6" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6. When you receive a command from a teammate, your phone will play the sound. You have 15 seconds to say \"OK\" to acknowledge without needing the wakeup phrase."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6. כאשר תתקבל הודעה מחבר, ניתן במשך 10 שניות לומר OK ללא צורך במילת הערה"
          }
        }
      }
    },
    "help_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HOW TO USE"
